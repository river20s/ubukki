---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION } from '../consts';
import type { CategoryId } from '../consts';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const featuredProjects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .slice(0, 3);

const lastUpdated = new Date().toLocaleDateString('ko-KR', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout description={SITE_DESCRIPTION}>
  <div class="max-w-[680px] mx-auto px-5 py-12">

    <!-- 히어로 -->
    <section class="mb-16">
      <p class="section-label mb-6">main</p>
      <hr />
      <div class="mt-8 space-y-4 text-[var(--color-text-soft)] leading-[1.8]">
        <p>
          만드는 사람 강은빈(ubukki)입니다.
        </p>
        <p>
          생활과 밀접한 앱을 기획하고 개발합니다. 학습 과정에서의 궁금증을 포착하고 해결하는
          모야 리스트(Moya List), 친구들과의 아지트 같은 작업실을 온라인으로 옮겨온
          체크 메이트(Check Mate) 등을 만들고 있습니다.
        </p>
        <p>
          블로그에는 만드는 과정에서 떠올린 것, 마주친 문제, 구현하고 해결해가는 과정을
          기록으로 남깁니다.
        </p>
        <ul class="list-none pl-0 space-y-1 mt-2">
          <li><a href="/about">About me</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/projects">Projects</a></li>
          <li>
            <a href="/rss.xml" class="text-[var(--color-text-meta)] text-sm">RSS</a>
          </li>
        </ul>
        <p class="text-meta mt-6">이 웹사이트는 {lastUpdated}에 갱신되었습니다.</p>
      </div>
      <hr class="mt-8" />
    </section>

    <!-- 최근 글 -->
    <section class="mb-16">
      <div class="flex items-baseline justify-between mb-6">
        <p class="section-label">Recent Posts</p>
        <a href="/blog" class="text-xs text-[var(--color-text-meta)] no-underline hover:text-[var(--color-accent)] transition-colors duration-150">
          전체 보기 →
        </a>
      </div>
      {recentPosts.length === 0 ? (
        <p class="text-[var(--color-text-meta)] text-sm">아직 작성된 글이 없습니다.</p>
      ) : (
        <ul class="list-none pl-0 space-y-8">
          {recentPosts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category as CategoryId}
              tags={post.data.tags}
              slug={post.id}
            />
          ))}
        </ul>
      )}
    </section>

    <!-- 주요 프로젝트 -->
    {featuredProjects.length > 0 && (
      <section>
        <div class="flex items-baseline justify-between mb-6">
          <p class="section-label">Projects</p>
          <a href="/projects" class="text-xs text-[var(--color-text-meta)] no-underline hover:text-[var(--color-accent)] transition-colors duration-150">
            전체 보기 →
          </a>
        </div>
        <ul class="list-none pl-0 space-y-4">
          {featuredProjects.map((project) => (
            <li class="border border-[var(--color-rule)] rounded-[4px] p-4">
              <a href={`/projects/${project.id}`} class="no-underline group">
                <h3 class="text-base font-medium mt-0 mb-1 text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-150">
                  {project.data.title}
                </h3>
                <p class="text-[var(--color-text-soft)] text-sm mb-3 leading-relaxed">{project.data.description}</p>
                <div class="flex flex-wrap gap-1.5">
                  {project.data.techStack.map((tech: string) => (
                    <span class="text-xs bg-[var(--color-tag-bg)] text-[var(--color-text-meta)] px-2 py-0.5 rounded-sm">
                      {tech}
                    </span>
                  ))}
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

  </div>
</BaseLayout>
