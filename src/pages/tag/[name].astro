---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
  return tags.map((tag) => ({ params: { name: tag } }));
}

const { name } = Astro.params;

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.tags.includes(name!)))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`#${name} — Blog`} description={`#${name} 태그의 글 목록`}>
  <div class="max-w-[680px] mx-auto px-5 py-12">
    <p class="section-label mb-2">Tag</p>
    <h1>#{name}</h1>
    <hr />
    {posts.length === 0 ? (
      <p class="mt-8 text-[var(--color-text-meta)]">글이 없습니다.</p>
    ) : (
      <ul class="list-none pl-0 mt-8 space-y-8">
        {posts.map((post) => (
          <li class="border-b border-[var(--color-rule)] pb-8 last:border-none">
            <a href={`/blog/${post.id}`} class="no-underline group">
              <h2 class="text-lg font-medium mt-0 group-hover:text-[var(--color-accent)] transition-colors duration-150">
                {post.data.title}
              </h2>
              <p class="text-meta mt-1 mb-2">
                {post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
              <p class="text-[var(--color-text-soft)] text-sm">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>
