---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import type { CategoryId } from '../../../consts';

export async function getStaticPaths() {
  const PER_PAGE = 10;
  const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  const totalPages = Math.ceil(allPosts.length / PER_PAGE);

  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const page = i + 2; // 2페이지부터
    return {
      params: { page: String(page) },
      props: {
        posts: allPosts.slice((page - 1) * PER_PAGE, page * PER_PAGE),
        currentPage: page,
        totalPages,
      },
    };
  });
}

const { posts, currentPage, totalPages } = Astro.props;
---

<BaseLayout title={`Blog — ${currentPage}페이지`} description="강은빈의 블로그 글 목록">
  <div class="max-w-[680px] mx-auto px-5 py-12">
    <h1>Blog</h1>
    <hr />

    <ul class="list-none pl-0 mt-8 space-y-8">
      {posts.map((post: any) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category as CategoryId}
          tags={post.data.tags}
          slug={post.id}
        />
      ))}
    </ul>

    <!-- 페이지네이션 -->
    <nav class="mt-12 flex justify-between text-sm text-[var(--color-text-meta)]">
      <a
        href={currentPage === 2 ? '/blog' : `/blog/page/${currentPage - 1}`}
        class="no-underline hover:text-[var(--color-text)] transition-colors duration-150"
      >
        ← 이전
      </a>
      <span>{currentPage} / {totalPages}</span>
      {currentPage < totalPages && (
        <a
          href={`/blog/page/${currentPage + 1}`}
          class="no-underline hover:text-[var(--color-text)] transition-colors duration-150"
        >
          다음 →
        </a>
      )}
    </nav>
  </div>
</BaseLayout>
