---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="강은빈의 블로그 글 목록">
  <div class="max-w-[680px] mx-auto px-5 py-12">
    <h1>Blog</h1>
    <hr />
    {posts.length === 0 ? (
      <p class="mt-8 text-[var(--color-text-meta)]">아직 작성된 글이 없습니다.</p>
    ) : (
      <ul class="list-none pl-0 mt-8 space-y-8">
        {posts.map((post) => (
          <li class="border-b border-[var(--color-rule)] pb-8 last:border-none">
            <a href={`/blog/${post.id}`} class="no-underline group">
              <h2 class="text-lg font-medium mt-0 group-hover:text-[var(--color-accent)] transition-colors duration-150">
                {post.data.title}
              </h2>
              <p class="text-[var(--color-text-meta)] text-sm mt-1 mb-2">
                {post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
                {' · '}
                <span class="bg-[var(--color-tag-bg)] px-2 py-0.5 rounded-sm text-[var(--color-accent)] text-xs">{post.data.category}</span>
              </p>
              <p class="text-[var(--color-text-soft)] text-sm leading-relaxed">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>
