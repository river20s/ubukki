---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import type { CategoryId } from '../../consts';

const PER_PAGE = 10;

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 현재 페이지는 index.astro라서 1페이지만 처리. 2페이지 이상은 blog/[page].astro에서.
const posts = allPosts.slice(0, PER_PAGE);
const totalPages = Math.ceil(allPosts.length / PER_PAGE);
---

<BaseLayout title="Blog" description="강은빈의 블로그 글 목록">
  <div class="max-w-[680px] mx-auto px-5 py-12">
    <h1>Blog</h1>
    <hr />

    {posts.length === 0 ? (
      <p class="mt-8 text-[var(--color-text-meta)]">아직 작성된 글이 없습니다.</p>
    ) : (
      <ul class="list-none pl-0 mt-8 space-y-8">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category as CategoryId}
            tags={post.data.tags}
            slug={post.id}
          />
        ))}
      </ul>
    )}

    <!-- 페이지네이션 -->
    {totalPages > 1 && (
      <nav class="mt-12 flex justify-end">
        <a
          href="/blog/page/2"
          class="text-sm text-[var(--color-text-meta)] no-underline hover:text-[var(--color-text)] transition-colors duration-150"
        >
          다음 →
        </a>
      </nav>
    )}
  </div>
</BaseLayout>
