---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — 페이지를 찾을 수 없어요">
  <div class="max-w-[680px] mx-auto px-5 py-24 text-center">
    <p class="section-label mb-6">404</p>
    <h1 class="text-2xl">길을 잃었어요.</h1>
    <p class="text-[var(--color-text-soft)] mt-4 mb-8">
      거북이도 가끔은 방향을 잃습니다.<br />
      존재하지 않거나 이동된 페이지예요.
    </p>
    <a href="/" class="text-[var(--color-accent)] no-underline hover:underline">← 홈으로 돌아가기</a>
  </div>
</BaseLayout>
