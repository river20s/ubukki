---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.period.start.valueOf() - a.data.period.start.valueOf());
---

<BaseLayout title="Projects" description="강은빈이 만든 프로젝트들">
  <div class="max-w-[680px] mx-auto px-5 py-12">
    <h1>Projects</h1>
    <hr />
    {projects.length === 0 ? (
      <p class="mt-8 text-[var(--color-text-meta)]">아직 등록된 프로젝트가 없습니다.</p>
    ) : (
      <ul class="list-none pl-0 mt-8 space-y-4">
        {projects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            techStack={project.data.techStack}
            period={project.data.period}
            slug={project.id}
          />
        ))}
      </ul>
    )}
  </div>
</BaseLayout>
