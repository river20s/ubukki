---
interface Props {
  title: string;
  description: string;
  techStack: string[];
  period: { start: Date; end?: Date };
  slug: string;
}

const { title, description, techStack, period, slug } = Astro.props;

const startYear = period.start.getFullYear();
const endYear = period.end ? period.end.getFullYear() : '현재';
const periodLabel = startYear === endYear ? String(startYear) : `${startYear}–${endYear}`;
---

<li>
  <a href={`/projects/${slug}`} class="no-underline group block border border-[var(--color-rule)] rounded-[4px] p-5 hover:border-[var(--color-accent)] transition-colors duration-150">
    <div class="flex items-start justify-between gap-4 mb-2">
      <h2 class="text-base font-medium mt-0 text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-150">
        {title}
      </h2>
      <span class="text-meta shrink-0">{periodLabel}</span>
    </div>
    <p class="text-[var(--color-text-soft)] text-sm leading-relaxed mb-3">{description}</p>
    <div class="flex flex-wrap gap-1.5">
      {techStack.map((tech) => (
        <span class="text-xs bg-[var(--color-tag-bg)] text-[var(--color-text-meta)] px-2 py-0.5 rounded-sm">
          {tech}
        </span>
      ))}
    </div>
  </a>
</li>
