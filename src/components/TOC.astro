---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
  variant?: 'mobile' | 'desktop';
}
const { headings, variant = 'mobile' } = Astro.props;
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{tocHeadings.length > 0 && variant === 'mobile' && (
  <details class="border border-[var(--color-rule)] rounded-[4px] px-4 py-3 mb-8 max-w-[680px] mx-auto lg:hidden">
    <summary class="section-label cursor-pointer select-none">목차</summary>
    <nav class="mt-3">
      <ul class="space-y-1">
        {tocHeadings.map(h => (
          <li class={h.depth === 3 ? 'pl-4' : ''}>
            <a
              href={`#${h.slug}`}
              class="text-meta text-sm no-underline hover:text-[var(--color-accent)] transition-colors duration-150 block py-0.5"
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </details>
)}

{tocHeadings.length > 0 && variant === 'desktop' && (
  <nav class="sticky top-8 w-[200px] shrink-0 self-start">
    <p class="section-label mb-3">목차</p>
    <ul class="space-y-1">
      {tocHeadings.map(h => (
        <li class={h.depth === 3 ? 'pl-3' : ''}>
          <a
            href={`#${h.slug}`}
            data-toc-id={h.slug}
            class="text-[var(--color-text-meta)] text-sm no-underline hover:text-[var(--color-accent)] transition-colors duration-150 block py-0.5 leading-snug"
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

{variant === 'desktop' && tocHeadings.length > 0 && (
  <script is:inline>
    (function () {
      var links = document.querySelectorAll('[data-toc-id]');
      if (!links.length) return;
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          links.forEach(function (link) {
            var active = link.dataset.tocId === entry.target.id;
            link.style.color = active ? 'var(--color-accent)' : '';
            link.style.fontWeight = active ? '500' : '';
          });
        });
      }, { rootMargin: '0px 0px -70% 0px', threshold: 0 });
      document.querySelectorAll('article h2, article h3').forEach(function (el) {
        observer.observe(el);
      });
    })();
  </script>
)}
