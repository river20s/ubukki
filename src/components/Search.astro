---
// Pagefind UI를 모달로 띄우는 검색 컴포넌트.
// pagefind JS/CSS는 빌드 후 /pagefind/ 경로에 생성됨.
---

<!-- 검색 버튼 -->
<button
  id="search-open"
  aria-label="검색"
  title="검색 (단축키: /)"
  class="p-1.5 rounded text-[var(--color-text-meta)] hover:text-[var(--color-text)] transition-colors duration-150"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="8"/>
    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
</button>

<!-- 검색 모달 -->
<div
  id="search-modal"
  role="dialog"
  aria-modal="true"
  aria-label="검색"
  class="hidden fixed inset-0 z-[100] flex items-start justify-center pt-[15vh] px-4"
>
  <!-- 배경 dimmer -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/30"></div>

  <!-- 모달 본체 -->
  <div class="relative w-full max-w-[560px] bg-[var(--color-paper-bg)] rounded-[4px] border border-[var(--color-rule)] shadow-sm overflow-hidden">
    <div id="pagefind-ui-container"></div>
  </div>
</div>

<style>
  /* Pagefind UI 커스텀 스타일 */
  #pagefind-ui-container {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-paper-bg);
    --pagefind-ui-border: var(--color-rule);
    --pagefind-ui-tag: var(--color-tag-bg);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 3px;
    --pagefind-ui-font: 'Pretendard Variable', Pretendard, sans-serif;
    padding: 12px 16px 16px;
  }

  /* 입력창 */
  #pagefind-ui-container .pagefind-ui__search-input {
    background-color: var(--color-paper-bg);
    color: var(--color-text);
    border-color: var(--color-rule);
    font-size: 15px;
  }

  /* 결과 */
  #pagefind-ui-container .pagefind-ui__result-title {
    color: var(--color-accent);
    font-size: 15px;
  }

  #pagefind-ui-container .pagefind-ui__result-excerpt {
    color: var(--color-text-soft);
    font-size: 13px;
  }

  /* 결과 없음 */
  #pagefind-ui-container .pagefind-ui__message {
    color: var(--color-text-meta);
    font-size: 14px;
  }
</style>

<script is:inline>
  var pagefindLoaded = false;

  var modal = document.getElementById('search-modal');
  var backdrop = document.getElementById('search-backdrop');
  var openBtn = document.getElementById('search-open');

  async function loadPagefind() {
    if (pagefindLoaded) return;
    pagefindLoaded = true;
    // pagefind UI는 빌드 후 /pagefind/에 생성됨 — is:inline으로 Vite 처리 제외
    var mod = await import('/pagefind/pagefind-ui.js');
    new mod.PagefindUI({
      element: '#pagefind-ui-container',
      showSubResults: false,
      translations: {
        placeholder: '검색어를 입력하세요',
        zero_results: '[QUERY]에 대한 검색 결과가 없습니다.',
      },
    });
  }

  function openModal() {
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    loadPagefind().then(function () {
      setTimeout(function () {
        var input = modal.querySelector('input[type=text]');
        if (input) input.focus();
      }, 50);
    });
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  openBtn.addEventListener('click', openModal);
  backdrop.addEventListener('click', closeModal);

  document.addEventListener('keydown', function (e) {
    if (e.key === '/' && !['INPUT', 'TEXTAREA'].includes(e.target.tagName)) {
      e.preventDefault();
      openModal();
    }
    if (e.key === 'Escape') closeModal();
  });
</script>
