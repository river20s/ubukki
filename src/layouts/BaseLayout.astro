---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  pubDate?: Date;
  updatedDate?: Date;
  type?: 'website' | 'article';
}

const { title, description, ogImage, pubDate, updatedDate, type } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      pubDate={pubDate}
      updatedDate={updatedDate}
      type={type}
    />
    <!-- 테마 깜빡임 방지: 렌더링 전에 테마 적용 -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('ubukki-theme');
        const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.dataset.theme = stored ?? preferred;
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col" style="background-color: var(--color-page-bg);">
    <!-- 페이지 외곽 그린 배경 + 종이색 콘텐츠 영역 -->
    <div class="flex-1 flex flex-col mx-3 my-3 sm:mx-5 sm:my-5 rounded-[4px] paper">
      <Header />
      <main class="flex-1" data-pagefind-body>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
