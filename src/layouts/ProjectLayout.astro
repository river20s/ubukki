---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  techStack: string[];
  period: { start: Date; end?: Date };
  role: string;
  links: { github?: string; demo?: string; blog?: string };
}

const { title, description, techStack, period, role, links } = Astro.props;

const startFormatted = period.start.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long' });
const endFormatted = period.end
  ? period.end.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long' })
  : '진행 중';
---

<BaseLayout title={title} description={description}>
  <div class="max-w-[680px] mx-auto px-5 py-12">

    <!-- 브레드크럼 -->
    <p class="text-meta mb-4">
      <a href="/projects" class="no-underline hover:text-[var(--color-text)] transition-colors duration-150">Projects</a>
    </p>

    <!-- 헤더 -->
    <header class="mb-8">
      <h1 class="mb-2">{title}</h1>
      <p class="text-[var(--color-text-soft)] text-[17px] leading-relaxed mb-5">{description}</p>

      <!-- 메타 그리드 -->
      <dl class="grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-3 text-sm border-t border-[var(--color-rule)] pt-5">
        <div>
          <dt class="section-label mb-1">기간</dt>
          <dd class="text-[var(--color-text-soft)]">{startFormatted} — {endFormatted}</dd>
        </div>
        <div>
          <dt class="section-label mb-1">역할</dt>
          <dd class="text-[var(--color-text-soft)]">{role}</dd>
        </div>
        {techStack.length > 0 && (
          <div class="col-span-2 sm:col-span-1">
            <dt class="section-label mb-1">기술 스택</dt>
            <dd class="flex flex-wrap gap-1.5">
              {techStack.map((tech) => (
                <span class="text-xs bg-[var(--color-tag-bg)] text-[var(--color-text-meta)] px-2 py-0.5 rounded-sm">
                  {tech}
                </span>
              ))}
            </dd>
          </div>
        )}
      </dl>

      <!-- 링크 -->
      {(links.github || links.demo) && (
        <div class="flex gap-4 mt-5 pt-4 border-t border-[var(--color-rule)]">
          {links.github && (
            <a href={links.github} class="text-sm" target="_blank" rel="noopener noreferrer">
              GitHub →
            </a>
          )}
          {links.demo && (
            <a href={links.demo} class="text-sm" target="_blank" rel="noopener noreferrer">
              Demo →
            </a>
          )}
        </div>
      )}
    </header>

    <hr />

    <!-- 본문 (문제 → 접근 → 결과 구조는 MDX 작성자가 h2로 구분) -->
    <article class="prose mt-10">
      <slot />
    </article>

    <hr class="mt-12" />
    <footer class="mt-6 text-sm text-[var(--color-text-meta)]">
      <a href="/projects" class="no-underline hover:underline">← 목록으로</a>
    </footer>

  </div>
</BaseLayout>
